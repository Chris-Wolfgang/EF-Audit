{
    "Serilog": {
        "MinimumLevel": {
            "Default": "Information"
        },
        "WriteTo": [
            {
                "Name": "Console",
                "Args": {
                    "outputTemplate": "{Level:u3} {Message:lj}{NewLine}",
                    "restrictedToMinimumLevel": "Warning"
                }
            }
        ]
    }
}
